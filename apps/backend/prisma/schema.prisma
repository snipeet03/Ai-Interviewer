generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Interview {
  id                String   @id @default(uuid())
  githubMetadata    Json     
  status            InterviewStatus
  score             Int      @default(0)
  conversations     MessageType[]
}


model Conversation {
    id             String  @id @default(uuid())
    message        String 
    type           MessageType
    interviewId    String
    interview      Interview @relational(fileds : [interviewId], references : [id])
}


model MessageType {
    User
    Assistant
}

enum InterviewStatus {
    Pre
    InProgress 
    Done 
}

